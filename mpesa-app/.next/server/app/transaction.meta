{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/transaction/layout,_N_T_/transaction/page,_N_T_/transaction"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/transaction/__PAGE__",
    "/transaction",
    "/_index",
    "/_head"
  ]
}